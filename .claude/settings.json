{
  "_aciklama": "loopkit izin listesi + opsiyonel hook'lar (kullanici onayiyla etkin). Otomatik-commit+push Stop hook'u settings.local.json'dadir ve KORUNUR; Claude Code hook dizilerini olay bazinda birlestirir.",
  "permissions": {
    "allow": [
      "Bash(ls:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(pytest:*)",
      "Bash(python -m pytest:*)",
      "Bash(ruff:*)",
      "Bash(python scripts/evaluate.py:*)",
      "Bash(python scripts/dayaniklilik_testi.py:*)",
      "Read(*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "timeout": 30,
            "command": "python \"c:/Users/muham/Projects/teknofest-2026-kamu-evrak-akilli-ajan/.claude/hooks/format_edited.py\""
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "manual|auto",
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "timeout": 30,
            "command": "python \"c:/Users/muham/Projects/teknofest-2026-kamu-evrak-akilli-ajan/.claude/hooks/pre_compact.py\""
          }
        ]
      }
    ]
  }
}
