# ============================================================
# Ortam Değişkenleri Konfigürasyonu
# Bu dosyayı .env olarak kopyalayın ve değerleri güncelleyin
# ============================================================

# --- LLM API Anahtarları ---
# OpenAI API (isteğe bağlı - açık kaynak model kullanılıyorsa gerekli değil)
OPENAI_API_KEY=your_openai_api_key_here

# Hugging Face Token (model indirme için)
HF_TOKEN=your_huggingface_token_here

# --- Model Ayarları ---
# Kullanılacak LLM modeli
LLM_MODEL_NAME=meta-llama/Llama-3.1-8B-Instruct
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096

# Embedding modeli
EMBEDDING_MODEL_NAME=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# --- OCR Ayarları ---
# Tesseract OCR yolu (Windows)
TESSERACT_CMD=C:/Program Files/Tesseract-OCR/tesseract.exe
# Tesseract dili
TESSERACT_LANG=tur

# --- Vektör Veritabanı ---
CHROMA_PERSIST_DIR=./data/chroma_db
CHROMA_COLLECTION_NAME=mevzuat

# --- Uygulama Ayarları ---
APP_HOST=localhost
APP_PORT=8501
LOG_LEVEL=INFO
DEBUG=false

# --- Veri Dizinleri ---
DATA_RAW_DIR=./data/raw
DATA_PROCESSED_DIR=./data/processed
TEMPLATES_DIR=./src/templates
MEVZUAT_DIR=./data/raw/mevzuat_metinleri
