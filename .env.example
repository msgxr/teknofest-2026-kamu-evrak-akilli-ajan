# ============================================================
# Ortam Değişkenleri Konfigürasyonu
# Bu dosyayı .env olarak kopyalayın ve değerleri güncelleyin
#
# ÖNEMLİ: Hiçbir değer ayarlamazsanız sistem "offline" (kural
# tabanlı) modda TAM çalışır. LLM backend'i otomatik tespit
# edilir: OpenAI-uyumlu anahtar/base_url > Ollama > offline.
# ============================================================

# --- LLM Backend Seçimi ---
# Boş bırakılırsa otomatik tespit. Değerler: openai | ollama | offline
LLM_BACKEND=

# --- OpenAI-uyumlu API (OpenAI, OpenRouter, Groq, vLLM, LM Studio...) ---
# OPENAI_API_KEY veya LLM_OPENAI_API_KEY olarak verilebilir
OPENAI_API_KEY=
# Farklı bir sağlayıcı için taban URL (ör. https://openrouter.ai/api/v1)
LLM_BASE_URL=
# Kullanılacak model adı
LLM_MODEL_NAME=gpt-4o-mini

# --- Ollama (tamamen yerel çalıştırma) ---
LLM_OLLAMA_BASE_URL=http://localhost:11434
LLM_OLLAMA_MODEL=qwen2.5:7b

# --- Üretim Parametreleri ---
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096
LLM_TIMEOUT_SECONDS=90

# --- Embedding modeli (opsiyonel semantik arama) ---
EMBEDDING_MODEL_NAME=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# --- OCR Ayarları (opsiyonel; taranmış evraklar için) ---
# macOS/Linux: tesseract | Windows: C:/Program Files/Tesseract-OCR/tesseract.exe
TESSERACT_CMD=tesseract
TESSERACT_LANG=tur

# --- Vektör Veritabanı (opsiyonel) ---
CHROMA_PERSIST_DIR=./data/chroma_db
CHROMA_COLLECTION_NAME=mevzuat

# --- Uygulama Ayarları ---
APP_HOST=localhost
APP_PORT=8501
APP_LOG_LEVEL=INFO
APP_DEBUG=false
